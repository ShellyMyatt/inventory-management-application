<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="632.0" prefWidth="573.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="myatt.Controller.AddPartController">
   <children>
      <Label layoutX="76.0" layoutY="94.0" text="Add Part">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>

      <RadioButton fx:id="inHouseRadioButton" layoutX="184.0" layoutY="96.0" mnemonicParsing="false" onAction="#onActionPartInHouse" selected="true" text="In-House">
         <toggleGroup>
            <ToggleGroup fx:id="RadioButton" />
         </toggleGroup></RadioButton>
      <RadioButton fx:id="outsourcedRadioButton" layoutX="299.0" layoutY="96.0" mnemonicParsing="false" onAction="#onActionPartOutsourced" text="Outsourced" toggleGroup="$RadioButton" />

      <TextField fx:id="partID" disable="true" editable="false" layoutX="184.0" layoutY="158.0" text="Auto Gen" />
      <TextField fx:id="partName" layoutX="184.0" layoutY="194.0" />
      <TextField fx:id="partInv" layoutX="184.0" layoutY="232.0" />
      <TextField fx:id="partPrice" layoutX="184.0" layoutY="267.0" />
      <TextField fx:id="partMax" layoutX="184.0" layoutY="304.0" />
      <TextField fx:id="partMin" layoutX="391.0" layoutY="304.0" />
      <TextField fx:id="machineIDCompanyNameTf" layoutX="184.0" layoutY="342.0" />
      <Button layoutX="333.0" layoutY="416.0" mnemonicParsing="false" onAction="#saveButton" text="Save" />
      <Button layoutX="391.0" layoutY="416.0" mnemonicParsing="false" onAction="#cancelButton" text="Cancel" />
      <Label layoutX="87.0" layoutY="162.0" text="ID" />
      <Label layoutX="87.0" layoutY="198.0" text="Name" />
      <Label layoutX="87.0" layoutY="236.0" text="Inv" />
      <Label layoutX="87.0" layoutY="271.0" text="Price/Cost" />
      <Label layoutX="87.0" layoutY="308.0" text="Max" />
      <Label layoutX="354.0" layoutY="308.0" text="Min" />
      <Label fx:id="machineIDorCompanyNameLabel" layoutX="87.0" layoutY="346.0" text="Machine ID" />
   </children>
</AnchorPane>
